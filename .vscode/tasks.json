    {
      "label": "🎯 Biome: Watch Mode (Background LSP-like)",
      "type": "shell",
      "command": ".poly_gluttony\\scripts\\biome.cmd",
      "args": ["check", "--watch"],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": true,
        "clear": false
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(.*)",
          "file": 1,
          "line": 2,
          "column": 3,
          "message": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Started.*",
          "endsPattern": "^.*Watching.*"
        }
      }
    },
    {
      "label": "🔧 Biome: Format Current File",
