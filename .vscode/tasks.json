      "type": "shell",
      "command": "ruff",
      "args": [
        "check",
        ".",
        "--watch"
      ],
      "isBackground": true,
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "never",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": {
        "owner": "ruff",
        "source": "ruff",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "severity": "error",
        "pattern": {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+([A-Z]\\d+)\\s+(.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "code": 4,
          "message": 5
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Watching for file changes",
          "endsPattern": "^All checks passed|^Found \\d+ error"
        }
      }
    },
